{
  "name": "claude-otel-collector-server",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "npx prisma generate && tsx watch src/server.ts",
    "build": "npx prisma generate && tsc",
    "start": "node dist/server.js",
    "test": "npm run test:cleanup && cross-env NODE_ENV=test DATABASE_URL=file:./test.db vitest run",
    "test:watch": "cross-env NODE_ENV=test DATABASE_URL=file:./test.db vitest",
    "test:cleanup": "rimraf --glob \"prisma/test*.db\""
  },
  "dependencies": {
    "@claude-otel/lib": "*",
    "@mrgeoffrich/claude-agent-sdk-tap": "^0.1.3",
    "@paralleldrive/cuid2": "^2.2.2",
    "@prisma/client": "^6.16.2",
    "better-sqlite3": "^12.4.1",
    "cors": "^2.8.5",
    "dotenv": "^17.2.1",
    "express": "^5.2.1",
    "pino": "^9.9.0",
    "pino-http": "^10.5.0",
    "pino-pretty": "^13.1.1",
    "zod": "^4.1.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.13",
    "@types/express": "^5.0.3",
    "@types/node": "^20.4.0",
    "@types/supertest": "^6.0.3",
    "cross-env": "^10.0.0",
    "prisma": "^6.16.2",
    "rimraf": "^6.1.3",
    "supertest": "^7.1.4",
    "tsx": "^4.21.0",
    "typescript": "^5.1.6",
    "vitest": "^4.0.18"
  }
}
