{
  "name": "claude-otel-collector-server",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "npx prisma generate && tsx watch src/server.ts",
    "build": "npx prisma generate && tsc",
    "start": "node dist/server.js",
    "test": "npm run test:cleanup && cross-env NODE_ENV=test DATABASE_URL=file:./test.db vitest run",
    "test:watch": "cross-env NODE_ENV=test DATABASE_URL=file:./test.db vitest",
    "test:cleanup": "rimraf --glob \"prisma/test*.db\""
  },
  "dependencies": {
    "@claude-otel/lib": "*",
    "@mrgeoffrich/claude-agent-sdk-tap": "^0.1.4",
    "@paralleldrive/cuid2": "^3.3.0",
    "@prisma/client": "^6.16.2",
    "better-sqlite3": "^12.8.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/supertest": "^7.2.0",
    "cross-env": "^10.1.0",
    "prisma": "^6.16.2",
    "rimraf": "^6.1.3",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "vitest": "^4.1.1"
  }
}
