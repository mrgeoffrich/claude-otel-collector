generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Session {
  id                     String   @id // session.id from SDK
  userId                 String?
  orgId                  String?
  model                  String?
  appVersion             String?
  firstSeenAt            DateTime
  lastSeenAt             DateTime
  totalInputTokens       BigInt   @default(0)
  totalOutputTokens      BigInt   @default(0)
  totalCacheReadTokens   BigInt   @default(0)
  totalCacheCreationTokens BigInt @default(0)
  totalCostUsd           Float    @default(0)
  totalApiCalls          Int      @default(0)
  totalToolCalls         Int      @default(0)
  totalErrors            Int      @default(0)

  prompts Prompt[]

  @@index([lastSeenAt(sort: Desc)])
  @@map("sessions")
}

model Prompt {
  id                     String   @id // prompt.id from SDK
  sessionId              String
  timestamp              DateTime
  promptLength           Int?
  promptText             String?
  model                  String?
  totalInputTokens       BigInt   @default(0)
  totalOutputTokens      BigInt   @default(0)
  totalCacheReadTokens   BigInt   @default(0)
  totalCostUsd           Float    @default(0)
  apiCallCount           Int      @default(0)
  toolCallCount          Int      @default(0)
  errorCount             Int      @default(0)
  totalDurationMs        BigInt   @default(0)

  session      Session        @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  apiRequests  ApiRequest[]
  toolResults  ToolResult[]
  apiErrors    ApiError[]
  toolDecisions ToolDecision[]

  @@index([sessionId])
  @@index([timestamp(sort: Desc)])
  @@map("prompts")
}

model ApiRequest {
  id                       String   @id @default(cuid())
  promptId                 String
  sessionId                String
  timestamp                DateTime
  model                    String?
  durationMs               Int?
  costUsd                  Float?
  inputTokens              Int?
  outputTokens             Int?
  cacheReadInputTokens     Int?
  cacheCreationInputTokens Int?
  attributes               String?  // JSON string

  prompt Prompt @relation(fields: [promptId], references: [id], onDelete: Cascade)

  @@index([promptId])
  @@map("api_requests")
}

model ToolResult {
  id                  String   @id @default(cuid())
  promptId            String
  sessionId           String
  timestamp           DateTime
  toolName            String?
  success             Boolean?
  durationMs          Int?
  error               String?
  decisionSource      String?
  toolResultSizeBytes Int?
  toolParameters      String?
  attributes          String?  // JSON string

  prompt Prompt @relation(fields: [promptId], references: [id], onDelete: Cascade)

  @@index([promptId])
  @@map("tool_results")
}

model ApiError {
  id             String   @id @default(cuid())
  promptId       String
  sessionId      String
  timestamp      DateTime
  errorType      String?
  httpStatusCode Int?
  retryAttempt   Int?
  model          String?
  attributes     String?  // JSON string

  prompt Prompt @relation(fields: [promptId], references: [id], onDelete: Cascade)

  @@index([promptId])
  @@map("api_errors")
}

model ToolDecision {
  id        String   @id @default(cuid())
  promptId  String
  sessionId String
  timestamp DateTime
  toolName  String?
  decision  String?
  source    String?
  attributes String? // JSON string

  prompt Prompt @relation(fields: [promptId], references: [id], onDelete: Cascade)

  @@index([promptId])
  @@map("tool_decisions")
}

model MetricSnapshot {
  id         String   @id @default(cuid())
  timestamp  DateTime
  metricName String
  value      Float
  attributes String?  // JSON string

  @@index([metricName, timestamp(sort: Desc)])
  @@map("metric_snapshots")
}
