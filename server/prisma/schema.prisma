generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model AgentSession {
  id                 String   @id // session_id from envelope
  firstSeenAt        DateTime
  lastSeenAt         DateTime
  model              String?  // from system:init
  claudeCodeVersion  String?  // from system:init
  permissionMode     String?  // from system:init
  cwd                String?  // from tap:query_params
  initialPrompt      String?  // from tap:query_params (first ~500 chars)
  maxBudgetUsd       Float?   // from tap:query_params
  tools              String?  // JSON array of tool names
  toolsCount         Int?
  messageCount       Int      @default(0)
  status             String?  // latest: idle/running/requires_action

  // Result fields (populated when result message arrives)
  totalCostUsd       Float?
  durationMs         Int?
  numTurns           Int?
  isError            Boolean?

  messages AgentMessage[]
  conversationMessages ConversationMessage[]

  @@index([lastSeenAt(sort: Desc)])
  @@map("agent_sessions")
}

model AgentMessage {
  id              String   @id @default(cuid())
  sessionId       String
  sequence        Int
  timestamp       DateTime
  uuid            String   @unique
  type            String   // assistant, user, result, system, stream_event, etc.
  subtype         String?  // for system messages: init, status, api_retry, etc.
  rawMessage      String   // full JSON of the message field

  // Extracted metadata (queryable)
  model           String?  // from assistant messages
  parentToolUseId String?  // links tool call chains
  toolName        String?  // from tool_progress
  toolUseId       String?  // from tool_progress
  contentPreview  String?  // first ~200 chars of text content
  costUsd         Float?   // from result messages
  durationMs      Int?     // from result messages
  numTurns        Int?     // from result messages
  isError         Boolean? // from result messages

  session AgentSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([type])
  @@index([timestamp(sort: Desc)])
  @@map("agent_messages")
}

model ConversationMessage {
  id              String   @id @default(cuid())
  sessionId       String
  sequence        Int
  timestamp       DateTime
  uuid            String   @unique
  role            String

  userContent     String?
  textContent     String?
  toolCalls       String?
  toolCallCount   Int?
  model           String?
  stopReason      String?

  costUsd         Float?
  durationMs      Int?
  numTurns        Int?
  isError         Boolean?
  resultText      String?

  toolSummary     String?

  parentToolUseId String?

  session AgentSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, sequence])
  @@map("conversation_messages")
}
