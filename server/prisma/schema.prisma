generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Session {
  id                     String   @id // session.id from SDK
  userId                 String?
  orgId                  String?
  model                  String?
  appVersion             String?
  firstSeenAt            DateTime
  lastSeenAt             DateTime
  totalInputTokens       BigInt   @default(0)
  totalOutputTokens      BigInt   @default(0)
  totalCacheReadTokens   BigInt   @default(0)
  totalCacheCreationTokens BigInt @default(0)
  totalCostUsd           Float    @default(0)
  totalApiCalls          Int      @default(0)
  totalToolCalls         Int      @default(0)
  totalErrors            Int      @default(0)

  traceSpans TraceSpan[]

  @@index([lastSeenAt(sort: Desc)])
  @@map("sessions")
}

model TraceSpan {
  id                     String   @id @default(cuid())
  traceId                String
  spanId                 String   @unique
  parentSpanId           String?
  sessionId              String
  spanName               String   // e.g., "claude_code.llm_request"
  spanKind               Int?
  startTime              DateTime
  endTime                DateTime?
  durationMs             Int?

  // LLM request fields
  model                  String?
  querySource            String?  // "sdk", etc.
  inputTokens            Int?
  outputTokens           Int?
  cacheReadTokens        Int?
  cacheCreationTokens    Int?
  success                Boolean?
  attempt                Int?
  ttftMs                 Int?
  speed                  String?

  // Rich content
  systemPromptPreview    String?
  systemPromptHash       String?
  systemPromptLength     Int?
  tools                  String?  // JSON array of tool definitions
  toolsCount             Int?
  newContext              String?  // User input
  newContextMessageCount Int?
  systemReminders        String?
  systemRemindersCount   Int?
  responseModelOutput    String?
  responseHasToolCall    Boolean?

  // Catch-all
  attributes             String?  // JSON string

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([traceId])
  @@index([startTime(sort: Desc)])
  @@map("trace_spans")
}

model MetricSnapshot {
  id         String   @id @default(cuid())
  timestamp  DateTime
  metricName String
  value      Float
  attributes String?  // JSON string

  @@index([metricName, timestamp(sort: Desc)])
  @@map("metric_snapshots")
}
